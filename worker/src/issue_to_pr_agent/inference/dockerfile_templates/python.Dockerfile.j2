# Synthesized for a Python repo ({{ package_manager }}).
FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends git ripgrep \
    && rm -rf /var/lib/apt/lists/*
COPY . .
{% if package_manager == "uv" -%}
RUN pip install --no-cache-dir uv && uv sync --frozen || uv pip install -e .
{% elif package_manager == "poetry" -%}
RUN pip install --no-cache-dir poetry && poetry install --no-interaction --no-root || poetry install
{% else -%}
RUN pip install --no-cache-dir -e . 2>/dev/null \
    || pip install --no-cache-dir -r requirements.txt 2>/dev/null \
    || true
{% endif -%}
CMD ["sh", "-c", "{{ test_command }}"]
