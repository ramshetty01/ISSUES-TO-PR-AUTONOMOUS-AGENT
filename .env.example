# ---------------------------------------------------------------------------
# issue-to-pr-agent — environment template. Copy to .env and fill the secrets.
# Dev defaults (see packages/config/src/defaults.ts) backfill everything that is
# commented out below, so at minimum only the GitHub App section is required.
# ---------------------------------------------------------------------------

NODE_ENV=development
# PORT=3001

# --- GitHub App (REQUIRED) -------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- smee.io (webhook forwarding to localhost; run scripts/setup-smee.sh) ---
# SMEE_URL=https://smee.io/xxxxxxxx

# --- LocalStack (SQS + DynamoDB + S3) --------------------------------------
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# SQS_QUEUE_URL=http://localhost:4566/000000000000/itpr-jobs
# SQS_DLQ_URL=http://localhost:4566/000000000000/itpr-jobs-dlq
# DYNAMODB_BUDGET_TABLE=itpr-budget-ledger
# S3_ARTIFACTS_BUCKET=itpr-artifacts

# --- Observability (self-hosted Langfuse) ----------------------------------
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# --- LLM providers (free tier; all optional — mock always works) -----------
# LLM_PROVIDER_ORDER=nvidia_nim,gemini,groq,ollama,mock
# NVIDIA_NIM_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# --- Feature flags ----------------------------------------------------------
# BUDGET_LEDGER_FALLBACK_SQLITE=true
