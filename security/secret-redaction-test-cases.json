{
  "description": "Vectors the secret scrubber MUST redact. Tokens are fake, assembled from fragments. expectedRedacted replaces each match with [REDACTED:<kind>].",
  "placeholderFormat": "[REDACTED:<kind>]",
  "cases": [
    {
      "input": "cloning with token ghp_0123456789abcdefghijklmnopqrstuvwxyz now",
      "expectedRedacted": "cloning with token [REDACTED:github_token] now"
    },
    {
      "input": "fine-grained pat: github_pat_A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5",
      "expectedRedacted": "fine-grained pat: [REDACTED:github_pat]"
    },
    {
      "input": "aws creds AKIA -> AKIAIOSFODNN7EXAMPLE in ~/.aws/credentials",
      "expectedRedacted": "aws creds AKIA -> [REDACTED:aws_access_key_id] in ~/.aws/credentials"
    },
    {
      "input": "slack webhook uses xoxb-EXAMPLE-not-a-real-slack-token-zzzz for posting",
      "expectedRedacted": "slack webhook uses [REDACTED:slack_token] for posting"
    },
    {
      "input": "maps key AIzaSyD-fakeFAKE0000fakeFAKE1111fakeFAK embedded in config.js",
      "expectedRedacted": "maps key [REDACTED:google_api_key] embedded in config.js"
    },
    {
      "input": "Authorization: Bearer eyJhbGci.fakeheader.fakesignature-0000",
      "expectedRedacted": "Authorization: [REDACTED:bearer_token]"
    },
    {
      "input": "private key inline:\n-----BEGIN RSA PRIVATE KEY-----\nMIIFAKEfakeFAKEfakeFAKE0000fakeFAKEfakeFAKE\n-----END RSA PRIVATE KEY-----",
      "expectedRedacted": "private key inline:\n[REDACTED:private_key]"
    },
    {
      "input": "api_key=abcdef0123456789ABCDEF in settings.ini",
      "expectedRedacted": "[REDACTED:generic_secret] in settings.ini"
    },
    {
      "input": "password: hunter2hunter2hunter2 was set",
      "expectedRedacted": "[REDACTED:generic_secret] was set"
    },
    {
      "input": "this line has no secrets, only the sha 7f3a and a version 1.2.3",
      "expectedRedacted": "this line has no secrets, only the sha 7f3a and a version 1.2.3"
    }
  ]
}
