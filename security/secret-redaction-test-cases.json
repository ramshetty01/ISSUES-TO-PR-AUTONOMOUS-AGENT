{
  "description": "Vectors the secret scrubber MUST redact. Secret-like values are stored as fragments and assembled only by tests so this file never contains a complete credential-shaped string.",
  "placeholderFormat": "[REDACTED:<kind>]",
  "cases": [
    {
      "name": "github classic token",
      "inputParts": ["cloning with token ", "ghp", "_", "0123456789abcdefghijklmnopqrstuvwxyz", " now"],
      "expectedRedacted": "cloning with token [REDACTED:github_token] now"
    },
    {
      "name": "github fine-grained pat",
      "inputParts": [
        "fine-grained pat: ",
        "github",
        "_pat_",
        "A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5A1b2C3d4E5"
      ],
      "expectedRedacted": "fine-grained pat: [REDACTED:github_pat]"
    },
    {
      "name": "aws access key id",
      "inputParts": ["aws creds AKIA -> ", "AKIA", "IOSFODNN7", "EXAMPLE", " in ~/.aws/credentials"],
      "expectedRedacted": "aws creds AKIA -> [REDACTED:aws_access_key_id] in ~/.aws/credentials"
    },
    {
      "name": "slack token",
      "inputParts": ["slack webhook uses ", "xox", "b-", "123456789012", "-", "abcdefghijklmnop", " for posting"],
      "expectedRedacted": "slack webhook uses [REDACTED:slack_token] for posting"
    },
    {
      "name": "google api key",
      "inputParts": ["maps key ", "AIza", "Syabcdefghijklmnopqrstuvwxyz0123456", " embedded in config.js"],
      "expectedRedacted": "maps key [REDACTED:google_api_key] embedded in config.js"
    },
    {
      "name": "bearer token",
      "inputParts": ["Authorization: Bearer ", "eyJhbGciOi", ".", "JIUzI1NiIsInR5cCI6IkpXVCJ9"],
      "expectedRedacted": "Authorization: Bearer [REDACTED:bearer_token]"
    },
    {
      "name": "private key block",
      "inputParts": [
        "private key inline:\n",
        "-----BEGIN RSA PRIVATE KEY-----\n",
        "MIIEpAIBAAKCAQEA\n",
        "-----END RSA PRIVATE KEY-----"
      ],
      "expectedRedacted": "private key inline:\n[REDACTED:private_key]"
    },
    {
      "name": "generic api key assignment",
      "inputParts": ["api_key=", "abcdef0123456789ABCDEF", " in settings.ini"],
      "expectedRedacted": "api_key=[REDACTED:generic_secret] in settings.ini"
    },
    {
      "name": "generic password assignment",
      "inputParts": ["password: ", "superSecretValue123", " was set"],
      "expectedRedacted": "password: [REDACTED:generic_secret] was set"
    },
    {
      "name": "benign text",
      "inputParts": ["this line has no secrets, only the sha 7f3a and a version 1.2.3"],
      "expectedRedacted": "this line has no secrets, only the sha 7f3a and a version 1.2.3"
    }
  ]
}
